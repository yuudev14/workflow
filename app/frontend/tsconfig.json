{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    // TS 5 with moduleResolution "bundler" resolves "paths" relative to this
    // file, so baseUrl is not strictly required — it is set explicitly so
    // older or alternative resolvers anchor the alias the same way.
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "watchOptions": {
    "watchFile": "fixedPollingInterval"
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
