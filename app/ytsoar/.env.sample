DB_USER=postgres
DB_PASSWORD=password
DB_HOST=ytsoar_postgres
DB_PORT=5432
DB_NAME=ytsoar
MQ_USER=guest
MQ_PASSWORD=guest
MQ_HOST=ytsoar_rabbitmq
MQ_PORT=5672
PLAYBOOK_QUEUE=playbook
LOGGER_MODE=DEBUG
HTTP_ADDR=:8080
STATUS_EXCHANGE=playbook.status

# worker
SANDBOX_ADDR=localhost:50052
# nodes run concurrently within one playbook run
MAX_PARALLEL_NODES=4
# playbook messages one worker runs concurrently (MQ Qos prefetch)
PLAYBOOK_PREFETCH=1
# per-node execution timeout
NODE_TIMEOUT_SECONDS=300

# sandbox
SANDBOX_LISTEN_ADDR=:50052
CONNECTORS_DIR=../connectors
# memory caps for sandbox subprocesses; keep concurrency x cap under the
# sandbox container's memory limit
NODE_MEMORY_LIMIT_MB=256
PYTHON_MEMORY_LIMIT_MB=512


# --- Auth ---
# "development" or "production". In production the API refuses to start while
# JWT_SECRET is still the built-in default.
APP_ENV=development

# Signs every access and refresh token. Anyone holding it can mint valid
# sessions, so generate a private value per environment:
#   openssl rand -base64 48
JWT_SECRET=dev-secret

# Access tokens are not revocable, so keep the window short; the refresh token
# is the credential that gets rotated and revoked.
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_HOURS=168

# Seeded on first boot, and only while no user holds the admin role. Leave
# ADMIN_PASSWORD empty and no admin is created — the API logs a warning and
# nobody can sign in.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@ytsoar.local
ADMIN_PASSWORD=admin123!

# Exact origin allow-list, comma separated. A wildcard is not usable here:
# browsers reject "*" on credentialed requests. The same list is what the
# websocket handshake checks its Origin against.
CORS_ORIGINS=http://localhost:9999,http://localhost:3000

# Set true wherever the site is served over HTTPS.
COOKIE_SECURE=false

# NOTE on production topology: the refresh cookie is SameSite=Lax, which works
# because nginx serves the frontend and the API from one origin (:9999). If you
# split them across domains the browser stops sending the cookie on /refresh
# and the websocket handshake — that setup needs SameSite=None + Secure
# instead. Keeping the same-origin nginx shape in production avoids the whole
# problem. API routes are unaffected either way: they authenticate with the
# Authorization header, not the cookie.