DB_USER=postgres
DB_PASSWORD=password
DB_HOST=ytsoar_postgres
DB_PORT=5432
DB_NAME=ytsoar
MQ_USER=guest
MQ_PASSWORD=guest
MQ_HOST=ytsoar_rabbitmq
MQ_PORT=5672
PLAYBOOK_QUEUE=playbook
LOGGER_MODE=DEBUG
HTTP_ADDR=:8080
STATUS_EXCHANGE=playbook.status

# worker
SANDBOX_ADDR=localhost:50052
# nodes run concurrently within one playbook run
MAX_PARALLEL_NODES=4
# playbook messages one worker runs concurrently (MQ Qos prefetch)
PLAYBOOK_PREFETCH=1
# per-node execution timeout
NODE_TIMEOUT_SECONDS=300

# sandbox
SANDBOX_LISTEN_ADDR=:50052
CONNECTORS_DIR=../connectors
# memory caps for sandbox subprocesses; keep concurrency x cap under the
# sandbox container's memory limit
NODE_MEMORY_LIMIT_MB=256
PYTHON_MEMORY_LIMIT_MB=512
